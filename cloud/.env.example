# Copy to cloud/.env and fill in. Gitignored by default.
# Sourced by the bootstrap + run + push scripts.

# ─────────────────────────────────────────────────────────────────────
# AWS credentials (only needed locally to run `terraform apply` / `destroy`)
# Easier: configure a named profile in ~/.aws/credentials and just set
# AWS_PROFILE here. Avoids putting raw keys in a .env file.
# ─────────────────────────────────────────────────────────────────────
AWS_PROFILE=your-profile-name
AWS_REGION=us-gov-east-1   # or us-east-1 for commercial AWS

# Or, if you don't have a profile and must use raw keys, uncomment:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...    # if using temporary credentials (SSO/STS)

# ─────────────────────────────────────────────────────────────────────
# SSH — local public key to upload, restrict-SSH source CIDR
# ─────────────────────────────────────────────────────────────────────
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
# To find your current IP: curl -s https://checkip.amazonaws.com
ALLOWED_SSH_CIDR=0.0.0.0/0   # change to YOUR.IP/32 for proper hygiene

# ─────────────────────────────────────────────────────────────────────
# Instance shape — override if you want T4 instead of A10G, etc.
# ─────────────────────────────────────────────────────────────────────
INSTANCE_TYPE=g6.xlarge   # GovCloud default; commercial AWS can use g5.xlarge

# ─────────────────────────────────────────────────────────────────────
# GitHub — for `push_results.sh` to commit measurement JSONs back to the repo.
# Generate a FINE-GRAINED PAT at https://github.com/settings/tokens.
# Scope to a single repo with Contents: read+write, Metadata: read-only.
# ─────────────────────────────────────────────────────────────────────
GITHUB_PAT=
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@example.com
GIT_REPO=your-github-org/your-repo
GIT_BRANCH=your-branch-name

# ─────────────────────────────────────────────────────────────────────
# Future cloud providers (not yet implemented — placeholder)
# ─────────────────────────────────────────────────────────────────────
# AZURE_SUBSCRIPTION_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# GCP_PROJECT=
# GCP_CREDS_JSON_PATH=
