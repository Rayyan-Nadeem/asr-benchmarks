# depodash-asr — environment template
#
# Copy this file to `.env` and fill in the secrets at the top.
# `.env` is gitignored. Do NOT commit it.

# ---------------------------------------------------------------------------
# Secrets (mandatory)

# HuggingFace token with read access to:
#   - nvidia/parakeet-tdt-0.6b-v3                          (CC-BY-4.0, public)
#   - nvidia/nemotron-speech-streaming-en-0.6b             (CC-BY-4.0, public)
#   - nvidia/punctuation_en_distilbert                     (CC-BY-4.0, public)
#   - nvidia/multitalker-parakeet-streaming-0.6b-v1        (NVIDIA OpenModel, gated)
#   - nvidia/diar_streaming_sortformer_4spk-v2.1           (NVIDIA OpenModel, gated)
#   - pyannote/segmentation-3.0                            (gated, accept terms)
#   - pyannote/wespeaker-voxceleb-resnet34-LM              (gated, accept terms)
#
# Get one at: https://huggingface.co/settings/tokens
# Accept the gated-model terms by visiting each model card while logged in.
HF_TOKEN=

# ---------------------------------------------------------------------------
# Engine selection — auto-multispeaker is the production default
# (routes per-session based on transcription_config.speaker_diarization_config.max_speakers).
#
# Override for testing single engines:
#   ENGINE=multitalker-parakeet    force speaker-kernel engine (≤4 spk sessions)
#   ENGINE=nemotron-native         force pipeline streaming engine (any spks)
#   ENGINE=parakeet-nemo           highest WER ceiling, chunked-offline
#   ENGINE=nemotron-nemo           chunked-offline sibling of parakeet-nemo
#   ENGINE=fastconformer-hybrid    114M model — fits on 8 GB GPU or CPU
#   ENGINE=parakeet-onnx           CPU fallback for non-GPU hosts (~2 GB RAM)
#   ENGINE=nemotron-streaming      smaller CPU fallback (sherpa-onnx INT8)
#   ENGINE=whisper                 short clips only — fails on long-form courtroom
#   ENGINE=noop                    protocol smoke test, no real transcription
ENGINE=auto-multispeaker

# Diarizer selection — passthrough is correct for auto-multispeaker and
# multitalker-parakeet (they emit speaker labels internally). Pick a
# real diarizer when forcing a pipeline engine without internal labels:
#   DIARIZER=passthrough           default — preserves engine-emitted labels
#   DIARIZER=sortformer            streaming sortformer v2.1 with AOSC (GPU)
#   DIARIZER=pyannote              best AMI overlap, slower on CPU
DIARIZER=passthrough

# Punctuator selection — post-process layer that restores periods, commas,
# question marks, and capitalization. distilbert is the production default;
# set passthrough only for engine-raw A/B testing.
#   PUNCTUATOR=distilbert          default — NVIDIA punctuation_en_distilbert (110 MB)
#   PUNCTUATOR=passthrough         raw engine output, unchanged
PUNCTUATOR=distilbert

# ---------------------------------------------------------------------------
# Concurrency
#
# Per-stream VRAM (approximate):
#   multitalker-parakeet           ~5 GB
#   nemotron-native + sortformer   ~3 GB
#   parakeet-nemo                  ~5 GB
#   fastconformer-hybrid           ~2 GB
#   parakeet-onnx (CPU)            ~2 GB RAM
#
# Practical concurrency per GPU shape (multitalker / pipeline-fallback):
#   8 GB card     1 / 2
#   16 GB card    2-3 / 4-5
#   24 GB card    4-6 / 8-10
MAX_CONCURRENT_CONNECTIONS=4

# Soft cap on per-process VRAM (in GiB). Used by server/_gpu_cap.py.
# Tune to your card's actual capacity minus ~2 GB headroom for other
# system processes. On a 16 GB card, leave it at 14.
VRAM_LIMIT_GIB=14

# ---------------------------------------------------------------------------
# Logging
#
# DEBUG = chatty (engine internals + per-chunk timings)
# INFO  = production default — per-session lifecycle + warnings
# WARNING = only abnormal events
LOG_LEVEL=INFO
